# Copie para .env antes de subir:
# cp .env.example .env

# Porta pública da Evolution na VPS. Com proxy/HTTPS, mantenha 8080 interno.
EVOLUTION_PORT=8080

# URL pública da Evolution. Em VPS com domínio, use https://evolution.seudominio.com.
# Para teste local, use http://localhost:8080.
SERVER_URL=http://localhost:8080
SERVER_TYPE=http
SERVER_PORT=8080

# Chave usada pelo CRM no header apikey.
# Troque por uma chave longa e aleatória antes de expor na internet.
AUTHENTICATION_API_KEY=change-this-local-api-key

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# Logs
LOG_LEVEL=ERROR,WARN,INFO,LOG,WEBHOOKS
LOG_COLOR=true
LOG_BAILEYS=error

# Instâncias
DEL_INSTANCE=false
CONFIG_SESSION_PHONE_CLIENT=LeadFlow
CONFIG_SESSION_PHONE_NAME=Chrome

# Banco da Evolution
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change-this-postgres-password@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=leadflow_evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Redis
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=leadflow
CACHE_REDIS_SAVE_INSTANCES=false

# Webhook global para o CRM LeadFlow.
# Se o CRM estiver local, exponha com tunnel e use a URL pública:
# https://seu-tunnel.trycloudflare.com/api/webhooks/evolution
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://host.docker.internal:5173/api/webhooks/evolution
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_SET=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_DELETE=true
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_EVENTS_CONTACTS_SET=true
WEBHOOK_EVENTS_CONTACTS_UPSERT=true
WEBHOOK_EVENTS_CONTACTS_UPDATE=true
WEBHOOK_EVENTS_CHATS_SET=true
WEBHOOK_EVENTS_CHATS_UPSERT=true
WEBHOOK_EVENTS_CHATS_UPDATE=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_ERRORS=true

# Serviços internos do compose
POSTGRES_DB=evolution
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-this-postgres-password
